# GitHub Repository Secrets template for infra/deploy.
# Мок-значения. Не вставляйте реальные секреты в этот файл.

# SSH/deploy
SERVER_HOST=203.0.113.10
SERVER_USER=deploy_bot
SERVER_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----MOCK-----END OPENSSH PRIVATE KEY-----
DEPLOY_PUBLIC_KEY=ssh-ed25519 AAAAMOCK github-actions

# Domains
DOMAIN=example.com
API_DOMAIN=api.example.com

# PostgreSQL
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=mock_postgres_password

# Yandex Disk backup via WebDAV app password
YANDEX_DISK_USERNAME=user@example.com
YANDEX_DISK_APP_PASSWORD=mock_yandex_app_password
RCLONE_REMOTE_PATH=kartochki-online/postgres
